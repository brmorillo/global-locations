{
  "name": "@brmorillo/global-locations",
  "version": "4.0.3",
  "description": "Production-ready library for global location data — countries, states and cities behind one type-safe API. Dual CJS + ESM build.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts --fix",
    "lint:ci": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "bun run lint && bun run format",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "cross-env CI=true jest --coverage --ci --watchAll=false --silent --verbose=false",
    "release": "commit-and-tag-version",
    "commit": "cz"
  },
  "keywords": [
    "global-locations",
    "countries",
    "states",
    "cities",
    "typescript",
    "javascript",
    "nodejs",
    "utility",
    "esm",
    "commonjs",
    "iso-3166",
    "geography",
    "location-data"
  ],
  "author": "Bruno Morillo <bruno@rmorillo.com> (https://github.com/brmorillo)",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@brmorillo/utils": "14.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@types/jest": "29.5.14",
    "commit-and-tag-version": "12.7.3",
    "commitizen": "4.3.1",
    "cross-env": "7.0.3",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.27.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "15.5.2",
    "prettier": "3.5.3",
    "ts-jest": "29.4.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brmorillo/global-locations.git"
  },
  "bugs": {
    "url": "https://github.com/brmorillo/global-locations/issues"
  },
  "homepage": "https://github.com/brmorillo/global-locations#readme"
}
